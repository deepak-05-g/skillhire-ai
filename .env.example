# Backend Configuration
API_STR=/api/v1
ALLOWED_ORIGINS=http://localhost:8501,http://frontend:8501
# Leave unset for SQLite fallback/manual quick starts, or set to a managed DB URL.
# DATABASE_URL=postgresql+psycopg://skillhire:skillhire@localhost:5432/skillhire_ai

# Frontend Configuration
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8501
AUTH_BACKEND_URL=http://localhost:8000

# Firebase Google Sign-In Configuration (Optional)
# Create a Firebase web app, enable Authentication > Sign-in method > Google,
# then copy these values from Project settings > General > Your apps.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# AI Configuration (Optional)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=
# Keep false for low-memory/free deployments. Set true to use SentenceTransformers
# semantic embeddings instead of the lightweight TF-IDF fallback.
ENABLE_SENTENCE_TRANSFORMERS=false
# Keep false for fast local/Render demos. Set true only when GEMINI_API_KEY should
# call Gemini for free-form chat instead of the local advisor fallback.
ENABLE_GEMINI_CHAT=false
